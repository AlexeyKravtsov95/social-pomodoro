generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Core Entities
// ─────────────────────────────────────────────────────────────

model User {
  id         BigInt  @id @default(autoincrement())
  telegramId BigInt  @unique
  username   String?
  firstName  String?
  lastName   String?
  photoUrl   String?

  // Progress
  xp            Int       @default(0)
  level         Int       @default(1)
  streak        Int       @default(0)
  lastFocusDate DateTime? @db.Date

  // Team relation
  teamId BigInt?
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)

  // Sessions
  sessions FocusSession[]

  // Team memberships (if member of multiple teams in future)
  teamMemberships TeamMember[]

  // Quest progress
  questProgress UserQuestProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([telegramId])
  @@index([teamId])
  @@index([xp])
}

model Team {
  id          BigInt  @id @default(autoincrement())
  name        String
  description String?
  inviteCode  String  @unique @default(cuid())

  // Weekly progress
  weeklyGoal     Int      @default(1000) // XP goal for the week
  weeklyProgress Int      @default(0)
  weekStart      DateTime @default(now())

  // Members
  members       TeamMember[]
  directMembers User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inviteCode])
}

model TeamMember {
  id       BigInt   @id @default(autoincrement())
  userId   BigInt
  teamId   BigInt
  role     String   @default("member") // owner, member
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([userId])
}

model FocusSession {
  id     BigInt @id @default(autoincrement())
  userId BigInt
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session data
  duration    Int // in minutes (15, 25, 45, 60)
  startedAt   DateTime
  completedAt DateTime?

  // Rewards
  xpEarned Int @default(0)

  // Validation
  isValid    Boolean @default(true)
  flagged    Boolean @default(false)
  flagReason String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, completedAt])
  @@index([startedAt])
}

// ─────────────────────────────────────────────────────────────
// Weekly Reset Tracking
// ─────────────────────────────────────────────────────────────

model WeeklyReset {
  id          BigInt    @id @default(autoincrement())
  weekStart   DateTime  @unique
  weekEnd     DateTime
  completed   Boolean   @default(false)
  processedAt DateTime?

  createdAt DateTime @default(now())

  @@index([weekStart])
}

// ─────────────────────────────────────────────────────────────
// Quest System (simple daily quests)
// ─────────────────────────────────────────────────────────────

model DailyQuest {
  id          BigInt @id @default(autoincrement())
  name        String
  description String
  xpReward    Int    @default(50)

  // Quest type: focus_session, streak, team_focus
  type String

  // Target value (e.g., complete 3 sessions)
  target Int @default(1)

  active Boolean @default(true)

  createdAt DateTime @default(now())

  // Relations
  userProgress UserQuestProgress[]

  @@index([type])
}

model UserQuestProgress {
  id        BigInt   @id @default(autoincrement())
  userId    BigInt
  questId   BigInt
  progress  Int      @default(0)
  completed Boolean  @default(false)
  date      DateTime @db.Date

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest DailyQuest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, date])
  @@index([userId, date])
}
